<!DOCTYPE html>
<html>
<head>
  <base target="_top">
  <meta charset="UTF-8">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    :root { --kt-red: #E60012; --kt-gray: #333333; }
    body { font-family: 'Noto Sans KR', sans-serif; background-color: #f4f4f4; color: var(--kt-gray); }
    .kt-red-bg { background-color: var(--kt-red); }
    .kt-red-text { color: var(--kt-red); }
    .course-item:hover { background-color: #fafafa; }
    .status-badge { font-size: 11px; font-weight: 700; border-radius: 9999px; padding: 4px 14px; text-align: center; display: inline-block; width: 95px; }
    .global-apply-btn { background-color: var(--kt-red); color: white; font-weight: 700; padding: 12px 0; text-align: center; display: block; width: 100%; max-width: 400px; margin: 0 auto; border-radius: 12px; transition: background-color 0.2s; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); }
    .global-apply-btn:hover { background-color: #b30009; }
    
    /* 헤더 내 개강 기준 안내 강조 뱃지 스타일 */
    .header-notice-badge {
      font-size: 11px;
      font-weight: 700;
      color: var(--kt-red);
      background-color: white;
      border: 1px solid white;
      border-radius: 9999px;
      padding: 4px 14px;
      display: inline-flex;
      align-items: center;
      margin-top: 8px;
    }
  </style>
</head>
<body class="p-0 sm:p-4">

  <div class="max-w-4xl mx-auto bg-white shadow-lg rounded-xl overflow-hidden border border-gray-200">
    
    <div class="kt-red-bg p-4 sm:p-5 flex justify-between items-center flex-wrap gap-3">
      <div>
        <h1 class="text-white text-lg sm:text-xl font-bold tracking-tight">kt ds 컨소시엄 교육 신청인원 현황 조회</h1>
        <p class="text-white/80 text-[11px] sm:text-xs mt-1">실시간 수강신청 인원 및 개강 예측 정보를 확인하세요.</p>
        
        <div class="header-notice-badge">
          📢 10명 이상 신청 시 개강
        </div>
      </div>
      <div class="hidden sm:block text-white text-right text-xs opacity-80 self-start">
        kt ds 컨소시엄
      </div>
    </div>

    <div class="bg-red-50 border-b border-red-100 px-6 py-2.5 flex items-center justify-center space-x-2">
      <span class="text-base">⏱️</span>
      <span class="text-xs font-bold text-red-700 tracking-tight">본 데이터는 매일 오전 10시에 업데이트됩니다. 수강신청 시 참고해 주시기 바랍니다.</span>
    </div>

    <div class="p-3 border-b bg-gray-50 flex items-center">
      <div class="relative flex-1">
        <input type="text" id="search" placeholder="🔍 찾으시는 과정명을 입력하여 검색하세요..." oninput="filter()" 
               class="w-full px-4 py-2.5 text-sm border border-gray-300 rounded-lg outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500 transition-all shadow-sm">
      </div>
    </div>

    <div class="px-4 py-3 bg-gray-50 border-b border-gray-100">
      <a href="https://edu.ktdsuniversity.com/lecture/list.action" target="_blank" class="global-apply-btn">
        🖥️ 수강신청 사이트 바로가기
      </a>
    </div>

    <div class="hidden md:flex bg-gray-100 border-b px-6 py-2.5 text-xs font-bold text-gray-500 uppercase tracking-wider items-center">
      <div class="flex-1">과정명</div>
      <div class="w-64 text-center">교육 일정</div>
      <div class="w-24 text-center">신청인원</div>
      <div class="w-32 text-center">개강상태</div>
    </div>

    <div id="list" class="divide-y divide-gray-100"></div>

    <div class="p-6 bg-gray-50 border-t">
      <a href="https://edu.ktdsuniversity.com/lecture/list.action" target="_blank" class="global-apply-btn">
        🖥️ 수강신청 사이트 바로가기
      </a>
    </div>

  </div>

  <script>
    const data = <?!= JSON.stringify(data) ?>;

    window.onload = () => {
      render(data);
    };

    function getStatus(count) {
      if (count >= 10) return { txt: '개강 확정', bg: 'bg-red-50', txtColor: 'kt-red-text', border: 'border-red-300' };
      return { txt: '모집 중', bg: 'bg-gray-50', txtColor: 'text-gray-600', border: 'border-gray-200' };
    }

    function render(items) {
      const list = document.getElementById('list');
      list.innerHTML = items.length ? '' : '<div class="p-12 text-center text-gray-400 text-sm">검색 결과가 없습니다.</div>';
      
      items.forEach(item => {
        const status = getStatus(item.applicant);
        const html = `
          <div class="course-item flex flex-col md:flex-row md:items-center px-4 sm:px-6 py-4 gap-3 md:gap-0 border-b last:border-b-0">
            <div class="flex-1 min-w-0 pr-0 md:pr-4">
              <h2 class="text-sm sm:text-base font-bold text-gray-900 leading-snug break-keep">
                ${item.name}
              </h2>
            </div>

            <div class="w-full md:w-64 text-left md:text-center flex flex-col md:justify-center space-y-0.5 border-t md:border-t-0 pt-2 md:pt-0">
              <span class="text-xs font-semibold text-gray-700">${item.period}</span>
            </div>

            <div class="flex items-center justify-between md:justify-end w-full md:w-auto md:space-x-6 pt-2 md:pt-0 border-t md:border-t-0">
              <div class="w-24 text-left md:text-center">
                <span class="text-xs font-medium text-gray-400 md:hidden">신청인원: </span>
                <span class="text-sm font-bold text-gray-700">${item.applicant}<span class="text-xs font-normal text-gray-500 ml-0.5">명</span></span>
              </div>
              <div class="w-32 text-right">
                <span class="status-badge ${status.bg} ${status.txtColor} border ${status.border}">
                  ${status.txt}
                </span>
              </div>
            </div>
          </div>
        `;
        list.insertAdjacentHTML('beforeend', html);
      });
    }

    function filter() {
      const keyword = document.getElementById('search').value.trim().toLowerCase();
      const filtered = data.filter(d => d.name.toLowerCase().includes(keyword));
      render(filtered);
    }
  </script>
</body>
</html>
